# Database
DATABASE_URL=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_NAME=Taskflow
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME=Taskflow

# Email (Nodemailer)
EMAIL_USER=
EMAIL_PASS=
EMAIL_SERVICE=gmail
EMAIL_FROM_NAME=Taskflow

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4
OPENAI_EMBED_MODEL=text-embedding-3-small

# Groq
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Ollama (local embeddings / context)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_GENERATE_MODEL=llama3

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=tasksensei
PINECONE_ENVIRONMENT=

# Server
PORT=3000
HOSTNAME=localhost

# Prisma seed (optional — set before running `npx prisma db seed`)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=
